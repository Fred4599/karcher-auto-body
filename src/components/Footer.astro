---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0A0A0A] border-t border-white/10">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Logo + Tagline -->
      <div class="lg:col-span-1">
        <a href="/">
          <img
            src="https://karcherautobody.com/userdata/remo61/media/uploads/images/footerlogo.png"
            alt="Karcher Auto Body"
            class="h-14 w-auto mb-4"
          />
        </a>
        <p class="text-white/60 text-sm leading-relaxed">
          Nampa's trusted collision repair and auto body shop. Family owned, I-CAR trained, and committed to quality.
        </p>
        <div class="flex items-center gap-1 mt-4">
          {Array(5).fill(null).map(() => (
            <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
          <span class="text-white/60 text-xs ml-1">5-Star Rated</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-gold font-bold uppercase tracking-widest text-xs mb-5">Quick Links</h3>
        <ul class="space-y-3">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About Us' },
            { href: '/services', label: 'Our Services' },
            { href: '/contact', label: 'Contact Us' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/60 text-sm hover:text-gold transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-gold font-bold uppercase tracking-widest text-xs mb-5">Services</h3>
        <ul class="space-y-3">
          {[
            'Collision Repair',
            'Auto Painting',
            'Frame & Unibody Repair',
            'Paintless Dent Removal',
            'Custom Paint',
            'Fleet & Dealership',
          ].map(service => (
            <li>
              <a href="/services" class="text-white/60 text-sm hover:text-gold transition-colors">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-gold font-bold uppercase tracking-widest text-xs mb-5">Contact</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/60 text-sm">2302 W. Karcher Rd.<br />Nampa, ID 83651</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+12084639090" class="text-white/60 text-sm hover:text-gold transition-colors">(208) 463-9090</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:karcherautobody@gmail.com" class="text-white/60 text-sm hover:text-gold transition-colors">karcherautobody@gmail.com</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-white/60 text-sm">Mon–Fri: 7:30 AM – 5:00 PM<br />Weekend drop-off available</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Map -->
  <div class="w-full h-64">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2895.8234567890123!2d-116.58!3d43.59!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54aef17c00000001%3A0x0!2s2302+W+Karcher+Rd%2C+Nampa%2C+ID+83651!5e0!3m2!1sen!2sus!4v1234567890"
      width="100%"
      height="100%"
      style="border:0; filter: grayscale(80%) invert(90%);"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Karcher Auto Body location map"
    ></iframe>
  </div>

  <!-- Bottom Bar -->
  <div class="bg-black border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/40 text-xs">
        &copy; {currentYear} Karcher Auto Body. All rights reserved.
      </p>
      <div class="flex items-center gap-1 text-white/40 text-xs">
        <span>Member of</span>
        <span class="text-gold font-semibold">Nampa</span>
        <span>&</span>
        <span class="text-gold font-semibold">Caldwell</span>
        <span>Chambers of Commerce</span>
      </div>
    </div>
  </div>
</footer>
