---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand-dark/95 backdrop-blur-sm border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src="https://karcherautobody.com/userdata/remo61/media/uploads/images/footerlogo.png"
          alt="Karcher Auto Body"
          class="h-12 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-semibold tracking-wide uppercase transition-colors ${
              currentPath === link.href
                ? 'text-gold'
                : 'text-white/80 hover:text-gold'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-4">
        <a
          href="/contact"
          class="hidden sm:inline-flex items-center px-5 py-2.5 bg-brand-red text-white text-sm font-bold uppercase tracking-wide rounded-[10px] hover:bg-red-700 transition-colors"
        >
          Free Estimate
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden text-white p-2"
          aria-label="Toggle menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-brand-surface">
    <nav class="px-4 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-4 py-3 text-sm font-semibold uppercase tracking-wide rounded-lg transition-colors ${
            currentPath === link.href
              ? 'text-gold bg-white/5'
              : 'text-white/80 hover:text-gold hover:bg-white/5'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 px-4 py-3 bg-brand-red text-white text-sm font-bold uppercase tracking-wide rounded-[10px] text-center"
      >
        Free Estimate
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
