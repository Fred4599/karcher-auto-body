---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const hours = [
  { day: 'Monday', hours: '7:30 AM – 5:00 PM' },
  { day: 'Tuesday', hours: '7:30 AM – 5:00 PM' },
  { day: 'Wednesday', hours: '7:30 AM – 5:00 PM' },
  { day: 'Thursday', hours: '7:30 AM – 5:00 PM' },
  { day: 'Friday', hours: '7:30 AM – 5:00 PM' },
  { day: 'Saturday', hours: 'Closed (drop-off available)' },
  { day: 'Sunday', hours: 'Closed (drop-off available)' },
];

const serviceAreas = [
  'Nampa', 'Caldwell', 'Meridian', 'Boise', 'Eagle',
  'Middleton', 'Star', 'Kuna', 'Canyon County', 'Ada County',
];
---

<Layout
  title="Contact Us — Free Estimate in Nampa, ID"
  description="Contact Karcher Auto Body in Nampa, ID. Get a free estimate, call (208) 463-9090, or stop by at 2302 W. Karcher Rd. Mon–Fri 7:30 AM–5:00 PM."
>
  <Nav />

  <!-- Page Hero -->
  <section class="bg-brand-dark pt-32 pb-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-gold/5 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="text-gold text-xs font-bold uppercase tracking-widest">Contact Us</span>
        <h1 class="text-5xl sm:text-6xl font-black text-white mt-3 mb-6 leading-tight">
          Let's Get Your Car<br />
          <span class="text-gold">Back to Perfect</span>
        </h1>
        <p class="text-xl text-white/60 leading-relaxed">
          Reach out to the Karcher Auto Body team — we're ready to help and we respond promptly.
        </p>
      </div>
    </div>
  </section>

  <div class="h-1 bg-gold"></div>

  <!-- Contact Section -->
  <section class="bg-brand-surface py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- Contact Info -->
        <div>
          <p class="text-white/60 leading-relaxed mb-10">
            Whether you've just been in an accident, noticed some damage you want fixed, or have a project in mind, we're happy to talk. Contact us by phone, email, or the form, and we'll get back to you with an honest assessment and a free estimate.
          </p>

          <!-- Quick Contact Cards -->
          <div class="space-y-4 mb-12">
            <a
              href="tel:+12084639090"
              class="flex items-center gap-5 bg-brand-card border border-white/5 rounded-2xl p-5 hover:border-gold/30 transition-all group"
            >
              <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="text-gold text-xs font-bold uppercase tracking-wider mb-0.5">Phone</div>
                <div class="text-white font-bold text-lg">(208) 463-9090</div>
                <div class="text-white/40 text-xs">Click to call on mobile</div>
              </div>
              <svg class="w-4 h-4 text-white/20 group-hover:text-gold ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>

            <a
              href="mailto:karcherautobody@gmail.com"
              class="flex items-center gap-5 bg-brand-card border border-white/5 rounded-2xl p-5 hover:border-gold/30 transition-all group"
            >
              <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-gold text-xs font-bold uppercase tracking-wider mb-0.5">Email</div>
                <div class="text-white font-bold">karcherautobody@gmail.com</div>
              </div>
              <svg class="w-4 h-4 text-white/20 group-hover:text-gold ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>

            <div class="flex items-center gap-5 bg-brand-card border border-white/5 rounded-2xl p-5">
              <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="text-gold text-xs font-bold uppercase tracking-wider mb-0.5">Address</div>
                <div class="text-white font-bold">2302 W. Karcher Rd.</div>
                <div class="text-white/60 text-sm">Nampa, ID 83651</div>
              </div>
            </div>
          </div>

          <!-- Hours -->
          <div class="bg-brand-card border border-white/5 rounded-2xl p-6">
            <h3 class="text-gold font-bold uppercase tracking-widest text-xs mb-4">Business Hours</h3>
            <div class="space-y-2">
              {hours.map(({ day, hours: h }) => (
                <div class={`flex justify-between items-center py-1.5 border-b border-white/5 last:border-0 ${h.includes('Closed') ? 'opacity-50' : ''}`}>
                  <span class="text-white/70 text-sm font-medium">{day}</span>
                  <span class={`text-sm font-semibold ${h.includes('Closed') ? 'text-white/40' : 'text-white'}`}>{h}</span>
                </div>
              ))}
            </div>
            <p class="text-white/40 text-xs mt-4">After-hours and weekend drop-off available. Call to arrange.</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <div class="bg-brand-card border border-white/5 rounded-3xl p-8">
            <h2 class="text-2xl font-black text-white mb-2">Send Us a Message</h2>
            <p class="text-white/50 text-sm mb-8">
              We'll get back to you within one business day. For faster service, call <a href="tel:+12084639090" class="text-gold hover:underline">(208) 463-9090</a>.
            </p>

            <form
              name="contact"
              method="POST"
              action="/contact?success=true"
              class="space-y-5"
              data-netlify="true"
            >
              <input type="hidden" name="form-name" value="contact" />

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block text-white/60 text-xs font-bold uppercase tracking-wider mb-2">Name *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full bg-brand-surface border border-white/10 rounded-[10px] px-4 py-3 text-white placeholder-white/30 text-sm focus:outline-none focus:border-gold/50 transition-colors"
                    placeholder="Your full name"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-white/60 text-xs font-bold uppercase tracking-wider mb-2">Phone *</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full bg-brand-surface border border-white/10 rounded-[10px] px-4 py-3 text-white placeholder-white/30 text-sm focus:outline-none focus:border-gold/50 transition-colors"
                    placeholder="(208) 000-0000"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-white/60 text-xs font-bold uppercase tracking-wider mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full bg-brand-surface border border-white/10 rounded-[10px] px-4 py-3 text-white placeholder-white/30 text-sm focus:outline-none focus:border-gold/50 transition-colors"
                  placeholder="your@email.com"
                />
              </div>

              <div>
                <label for="vehicle" class="block text-white/60 text-xs font-bold uppercase tracking-wider mb-2">Vehicle</label>
                <input
                  type="text"
                  id="vehicle"
                  name="vehicle"
                  class="w-full bg-brand-surface border border-white/10 rounded-[10px] px-4 py-3 text-white placeholder-white/30 text-sm focus:outline-none focus:border-gold/50 transition-colors"
                  placeholder="Year, Make, Model (e.g. 2019 Toyota Camry)"
                />
              </div>

              <div>
                <label for="contact-method" class="block text-white/60 text-xs font-bold uppercase tracking-wider mb-2">Preferred Contact</label>
                <select
                  id="contact-method"
                  name="contact-method"
                  class="w-full bg-brand-surface border border-white/10 rounded-[10px] px-4 py-3 text-white text-sm focus:outline-none focus:border-gold/50 transition-colors"
                >
                  <option value="phone">Phone call</option>
                  <option value="text">Text message</option>
                  <option value="email">Email</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-white/60 text-xs font-bold uppercase tracking-wider mb-2">Description of Damage / Message *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full bg-brand-surface border border-white/10 rounded-[10px] px-4 py-3 text-white placeholder-white/30 text-sm focus:outline-none focus:border-gold/50 transition-colors resize-none"
                  placeholder="Tell us what happened and what you're looking for..."
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full px-8 py-4 bg-brand-red text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-red-700 transition-colors text-sm"
              >
                Send My Message
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="bg-brand-dark py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-gold text-xs font-bold uppercase tracking-widest">Serving</span>
        <h2 class="text-3xl font-black text-white mt-2">The Treasure Valley</h2>
        <p class="text-white/50 mt-2 text-sm">If you're not sure if we cover your area, just call — we'll let you know.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {serviceAreas.map(area => (
          <span class="bg-brand-surface border border-white/5 text-white/60 text-sm px-4 py-2 rounded-full">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Map -->
  <div class="w-full h-80">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2895.8234567890123!2d-116.58!3d43.59!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54aef17c00000001%3A0x0!2s2302+W+Karcher+Rd%2C+Nampa%2C+ID+83651!5e0!3m2!1sen!2sus!4v1234567890"
      width="100%"
      height="100%"
      style="border:0; filter: grayscale(60%) invert(85%);"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Karcher Auto Body location — 2302 W. Karcher Rd, Nampa, ID"
    ></iframe>
  </div>

  <!-- CTA Closing -->
  <section class="bg-brand-surface py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-black text-white mb-3">We're a Phone Call Away</h2>
      <p class="text-white/60 mb-8">
        Questions about a repair? Not sure what your damage will cost? Call us and talk to a real person. We're here Monday through Friday, 7:30 to 5:00, and happy to help.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:+12084639090"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-red text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-red-700 transition-colors text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (208) 463-9090
        </a>
        <a
          href="mailto:karcherautobody@gmail.com"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-semibold rounded-[10px] hover:border-gold hover:text-gold transition-all text-sm"
        >
          Or Email Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
