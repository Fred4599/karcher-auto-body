---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Collision Repair',
    desc: 'Full structural and surface restoration for vehicles of all makes and models. We bring your car back to pre-accident condition — safely and correctly.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9" /></svg>`,
  },
  {
    title: 'Auto Painting',
    desc: 'Precision paint matching and professional respray. Whether it\'s a panel repair or a full color change, your finish will look factory-fresh.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
  },
  {
    title: 'Paintless Dent Removal',
    desc: 'Fast, affordable dent and ding removal without the need for repainting. Perfect for hail damage, door dings, and minor dents.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  },
  {
    title: 'Frame & Unibody Repair',
    desc: 'Structural damage requires precision. We use professional frame equipment to restore your vehicle\'s alignment, safety, and integrity.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" /></svg>`,
  },
];

const stats = [
  { value: '50+', label: 'Years Combined Experience' },
  { value: '5★', label: 'Star Rated' },
  { value: 'All', label: 'Makes & Models' },
  { value: '100%', label: 'Family Owned' },
];

const whyUs = [
  { title: 'Owner on Site', desc: 'Erick is personally involved in every job. You\'ll always know who you\'re talking to.' },
  { title: 'I-CAR Trained Technicians', desc: 'Our team meets rigorous industry training standards so your repair is done right.' },
  { title: 'Honest Communication', desc: 'We explain exactly what needs to be done and why, with no surprises.' },
  { title: 'All Makes & Models', desc: 'Domestic, import, project cars, fleet vehicles — we work on them all.' },
  { title: 'Free Estimates', desc: 'Know what to expect before we start. No pressure, no obligation.' },
  { title: 'Local & Accountable', desc: 'Members of Nampa and Caldwell Chambers of Commerce, proud to serve the Treasure Valley.' },
];

const reviews = [
  {
    text: "Erick and his team did a fantastic job on my truck. They kept me informed every step of the way and the work was flawless. I wouldn't take my vehicles anywhere else.",
    author: 'Satisfied Customer',
    location: 'Nampa, ID',
  },
  {
    text: "After my accident I was stressed and didn't know where to turn. Karcher Auto Body made the whole process easy — from the estimate to dealing with insurance to picking up my car. Highly recommend.",
    author: 'Satisfied Customer',
    location: 'Caldwell, ID',
  },
  {
    text: "The quality of work is outstanding. My car looks better than before the accident. Fair pricing, friendly staff, and the owner actually came out and introduced himself. That's rare these days.",
    author: 'Satisfied Customer',
    location: 'Nampa, ID',
  },
];
---

<Layout title="Nampa's Trusted Auto Body Experts">
  <Nav />

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-brand-dark pt-20">
    <!-- Hero background image -->
    <div class="absolute inset-0">
      <img
        src="/images/hero-shop-exterior.jpg"
        alt="Karcher Auto Body shop exterior"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-brand-dark/80"></div>
    </div>

    <!-- Gold gradient accent -->
    <div class="absolute top-1/4 -right-32 w-96 h-96 bg-gold/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 -left-32 w-96 h-96 bg-brand-red/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-gold/10 border border-gold/20 text-gold text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-8">
        <span class="w-1.5 h-1.5 bg-gold rounded-full"></span>
        I-CAR Trained · Family Owned · Free Estimates
      </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[1.05] mb-6 tracking-tight">
        Nampa's Trusted<br />
        <span class="text-gold">Auto Body</span> Experts.
      </h1>

      <p class="text-lg sm:text-xl text-white/60 max-w-2xl mx-auto mb-10 leading-relaxed">
        50+ Years of Combined Experience. I-CAR Trained Technicians.<br class="hidden sm:block" /> Family Owned and Operated.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-red text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-red-700 transition-all text-sm shadow-lg shadow-brand-red/20"
        >
          Get a Free Estimate
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="tel:+12084639090"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-semibold rounded-[10px] hover:border-gold hover:text-gold transition-all text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (208) 463-9090
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <div class="w-px h-8 bg-white/20 animate-pulse"></div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-gold">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map(stat => (
          <div>
            <div class="text-3xl sm:text-4xl font-black text-brand-dark">{stat.value}</div>
            <div class="text-brand-dark/70 text-xs font-semibold uppercase tracking-wide mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Business Intro -->
  <section class="bg-brand-surface py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-gold text-xs font-bold uppercase tracking-widest">About Us</span>
          <h2 class="text-4xl sm:text-5xl font-black text-white mt-3 mb-6 leading-tight">
            Collision Repair Done Right — By People Who Care
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mb-6">
            At Karcher Auto Body, we know a damaged car isn't just an inconvenience — it's stressful. That's why we treat every vehicle like it's our own and every customer like a neighbor, because in Nampa, you probably are.
          </p>
          <p class="text-white/60 leading-relaxed mb-8">
            Our team of I-CAR trained technicians brings decades of hands-on experience to every repair, and our owner Erick is personally involved to make sure the job gets done right. We're not a chain. We're your local shop — and that makes all the difference.
          </p>
          <a href="/about" class="inline-flex items-center gap-2 text-gold font-semibold hover:gap-3 transition-all">
            Learn Our Story
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-brand-card rounded-2xl p-6 border border-white/5">
            <div class="text-gold mb-3">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-white font-bold mb-1">I-CAR Certified</h3>
            <p class="text-white/50 text-sm">Industry-standard training on every repair</p>
          </div>
          <div class="bg-brand-card rounded-2xl p-6 border border-white/5 mt-6">
            <div class="text-gold mb-3">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h3 class="text-white font-bold mb-1">Family Owned</h3>
            <p class="text-white/50 text-sm">Owner Erick is personally on every job</p>
          </div>
          <div class="bg-brand-card rounded-2xl p-6 border border-white/5">
            <div class="text-gold mb-3">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white font-bold mb-1">Free Estimates</h3>
            <p class="text-white/50 text-sm">No pressure, no obligation</p>
          </div>
          <div class="bg-brand-card rounded-2xl p-6 border border-white/5 mt-6">
            <div class="text-gold mb-3">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <h3 class="text-white font-bold mb-1">5-Star Rated</h3>
            <p class="text-white/50 text-sm">Trusted by the Treasure Valley</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-brand-dark py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-gold text-xs font-bold uppercase tracking-widest">What We Do</span>
        <h2 class="text-4xl sm:text-5xl font-black text-white mt-3 mb-4">From fender benders to full rebuilds.</h2>
        <p class="text-white/50 max-w-xl mx-auto">We handle it all — any make, any model, any job size.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {services.map(service => (
          <div class="group bg-brand-surface border border-white/5 rounded-2xl p-6 hover:border-gold/30 transition-all">
            <div class="text-gold mb-4" set:html={service.icon} />
            <h3 class="text-white font-bold text-lg mb-2">{service.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed mb-4">{service.desc}</p>
            <a href="/services" class="text-gold text-sm font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Learn More
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/services" class="inline-flex items-center gap-2 px-6 py-3 border border-gold/40 text-gold font-semibold rounded-[10px] hover:bg-gold hover:text-brand-dark transition-all text-sm">
          See All Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-brand-surface py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-gold text-xs font-bold uppercase tracking-widest">Why Karcher</span>
        <h2 class="text-4xl sm:text-5xl font-black text-white mt-3">Why Nampa Trusts Karcher Auto Body</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {whyUs.map((item, i) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-gold/10 border border-gold/20 rounded-lg flex items-center justify-center text-gold font-black text-sm">
              {i + 1}
            </div>
            <div>
              <h3 class="text-white font-bold mb-1">{item.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gold py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl sm:text-5xl font-black text-brand-dark mb-4">Ready to Get Your Car Back to Perfect?</h2>
      <p class="text-brand-dark/70 text-lg mb-8 max-w-xl mx-auto">
        Don't wait on damage that can worsen over time. Contact Karcher Auto Body today for a free, no-obligation estimate.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-dark text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-brand-surface transition-all text-sm"
        >
          Request a Free Estimate
        </a>
        <a
          href="tel:+12084639090"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 text-brand-dark font-semibold text-sm"
        >
          Or call us at (208) 463-9090
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-brand-dark py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-gold text-xs font-bold uppercase tracking-widest">Testimonials</span>
        <h2 class="text-4xl sm:text-5xl font-black text-white mt-3">What Our Customers Are Saying</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {reviews.map(review => (
          <div class="bg-brand-surface border border-white/5 rounded-2xl p-8">
            <div class="flex items-center gap-0.5 mb-4">
              {Array(5).fill(null).map(() => (
                <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-white/70 leading-relaxed mb-6 italic">"{review.text}"</p>
            <div>
              <div class="text-white font-semibold text-sm">{review.author}</div>
              <div class="text-white/40 text-xs">{review.location}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
