---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'collision-repair',
    title: 'Collision Repair',
    intro: "Been in an accident? We restore vehicles to their pre-collision condition — safely, correctly, and with attention to every detail.",
    body: "Our technicians handle everything from surface panel repairs to complex structural work, working with all makes and models. We also work with most insurance carriers to keep the process smooth.",
    forWho: "Anyone dealing with accident damage, regardless of severity.",
    result: "A complete repair that looks and performs like nothing happened.",
    image: "/images/service-collision-repair.jpg",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9" /></svg>`,
  },
  {
    id: 'auto-painting',
    title: 'Auto Painting',
    intro: "Professional paint work requires more than a steady hand — it requires an eye for color, knowledge of paint chemistry, and the right equipment.",
    body: "Our team delivers precise color matching and flawless application on everything from single panels to full vehicle resprays.",
    forWho: "Vehicles needing paint repair after damage, fading, or scratching — or anyone ready for a color refresh.",
    result: "A factory-quality finish that holds up over time.",
    image: "/images/service-auto-painting.jpg",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
  },
  {
    id: 'frame-unibody',
    title: 'Frame & Unibody Repair',
    intro: "Collision damage often goes deeper than what you can see. When structural integrity is compromised, it affects how your vehicle handles, protects, and performs.",
    body: "We use professional frame repair equipment to restore your vehicle's geometry to manufacturer specifications.",
    forWho: "Vehicles with structural damage from moderate-to-severe collisions.",
    result: "A safe, properly aligned vehicle — not just a cosmetically repaired one.",
    image: "/images/service-frame-unibody-repair.jpg",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" /></svg>`,
  },
  {
    id: 'cosmetic-repair',
    title: 'Cosmetic Damage Repair',
    intro: "Scrapes, dings, and minor dents might seem small, but they can affect your vehicle's value and your pride in it.",
    body: "We repair cosmetic damage efficiently and affordably, bringing your car's appearance back to where it should be.",
    forWho: "Car owners with minor surface damage who want it fixed right.",
    result: "Seamless repair without unnecessary panel replacement or overspray.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>`,
  },
  {
    id: 'pdr',
    title: 'Paintless Dent Removal',
    intro: "For dents and dings that haven't broken the paint surface, PDR is the fastest and most affordable solution.",
    body: "No filler, no repainting — just precise, technique-driven repair that preserves your factory finish.",
    forWho: "Vehicles with hail damage, parking lot dings, or minor dents where the paint is intact.",
    result: "Dent-free panels without the cost or time of conventional repair.",
    image: "/images/service-paintless-dent-removal.jpg",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  },
  {
    id: 'custom-paint',
    title: 'Custom Paint Applications',
    intro: "Want something beyond stock? We work with customers on custom color applications, specialty finishes, and unique paint jobs.",
    body: "Whether you're building a show car or just want to stand out, our team has the skill to execute your vision.",
    forWho: "Project car builders, car enthusiasts, and anyone seeking a custom look.",
    result: "A finish that's uniquely yours — applied with professional quality.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>`,
  },
  {
    id: 'restoration',
    title: 'Vehicle Restoration & Rebuilding',
    intro: "Restoring a classic or rebuilding a project vehicle takes patience, skill, and a team that cares about the end result.",
    body: "We work with enthusiasts on restoration work from body prep to final paint, bringing old vehicles back to life.",
    forWho: "Classic car owners, collectors, and project car builders.",
    result: "Expert body and paint work that honors the vehicle's history and your vision for it.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
  },
  {
    id: 'fleet',
    title: 'Fleet & Dealership Services',
    intro: "We work with local businesses and dealerships that need reliable, high-volume auto body work.",
    body: "From fleet vehicles back in service quickly to dealership inventory needing reconditioning, we understand the unique demands of commercial accounts.",
    forWho: "Fleet managers, car dealerships, and commercial vehicle operators in the Treasure Valley.",
    result: "Quality repairs on your schedule, with the accountability of a local partner.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  },
  {
    id: 'insurance',
    title: 'Insurance Claim Assistance',
    intro: "Dealing with an insurance claim after an accident is stressful enough. We help guide you through the process.",
    body: "From documentation to communicating with your adjuster — so you can focus on getting back to normal.",
    forWho: "Anyone navigating an insurance claim for vehicle damage.",
    result: "Expert guidance and an advocate on your side throughout the claim process.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  },
];
---

<Layout
  title="Auto Body & Collision Repair Services in Nampa, Idaho"
  description="Full-service auto body repair in Nampa, Idaho — collision repair, auto painting, frame repair, PDR, custom paint, fleet services, and insurance claim help."
>
  <Nav />

  <!-- Page Hero -->
  <section class="bg-brand-dark pt-32 pb-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-gold/5 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="text-gold text-xs font-bold uppercase tracking-widest">Our Services</span>
        <h1 class="text-5xl sm:text-6xl font-black text-white mt-3 mb-6 leading-tight">
          Full-Service Auto Body<br />
          <span class="text-gold">Repair in Nampa, Idaho</span>
        </h1>
        <p class="text-xl text-white/60 leading-relaxed mb-8">
          From collision damage to custom finishes — we have the expertise to restore, repair, and transform your vehicle.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-red text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-red-700 transition-colors text-sm"
        >
          Get a Free Estimate
        </a>
      </div>
    </div>
  </section>

  <div class="h-1 bg-gold"></div>

  <!-- Overview -->
  <section class="bg-brand-surface py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/60 text-lg leading-relaxed">
        At Karcher Auto Body, we offer comprehensive auto body and collision repair services for all makes and models — imports included. Our I-CAR trained technicians use professional-grade equipment and proven techniques to deliver results that meet or exceed pre-accident condition.
      </p>
      <p class="text-gold font-semibold mt-4">All services include a free estimate.</p>
    </div>
  </section>

  <!-- Services List -->
  <section class="bg-brand-dark py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-6">
        {services.map((service, i) => (
          <div id={service.id} class="group bg-brand-surface border border-white/5 rounded-2xl overflow-hidden hover:border-gold/20 transition-all">
            {service.image && (
              <div class="h-48 overflow-hidden">
                <img
                  src={service.image}
                  alt={service.title + ' — Karcher Auto Body'}
                  class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class={`grid lg:grid-cols-3 gap-8 items-start p-8`}>
              <!-- Title & Icon -->
              <div class="lg:col-span-1">
                <div class="text-gold mb-4" set:html={service.icon} />
                <h2 class="text-2xl font-black text-white mb-2">{service.title}</h2>
                <p class="text-white/60 leading-relaxed">{service.intro}</p>
              </div>

              <!-- Details -->
              <div class="lg:col-span-1">
                <p class="text-white/50 leading-relaxed mb-6">{service.body}</p>
                <div class="space-y-3">
                  <div>
                    <span class="text-gold text-xs font-bold uppercase tracking-wider">Who it's for</span>
                    <p class="text-white/60 text-sm mt-1">{service.forWho}</p>
                  </div>
                  <div>
                    <span class="text-gold text-xs font-bold uppercase tracking-wider">What you get</span>
                    <p class="text-white/60 text-sm mt-1">{service.result}</p>
                  </div>
                </div>
              </div>

              <!-- CTA -->
              <div class="lg:col-span-1 flex flex-col justify-between gap-4 lg:items-end lg:text-right">
                <a
                  href="/contact"
                  class="inline-flex items-center gap-2 px-6 py-3 bg-brand-red text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-red-700 transition-colors text-sm whitespace-nowrap"
                >
                  Request Free Estimate
                </a>
                <a
                  href="tel:+12084639090"
                  class="text-white/40 text-sm hover:text-gold transition-colors"
                >
                  (208) 463-9090
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gold py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl sm:text-5xl font-black text-brand-dark mb-4">Not Sure What You Need?</h2>
      <p class="text-brand-dark/70 text-lg mb-8 max-w-xl mx-auto">
        Bring your vehicle in or give us a call. We'll assess the damage honestly and walk you through your options — no pressure, no obligation.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-dark text-white font-bold uppercase tracking-wide rounded-[10px] hover:bg-brand-surface transition-all text-sm"
        >
          Schedule a Free Estimate
        </a>
        <a href="tel:+12084639090" class="text-brand-dark font-semibold text-sm">
          (208) 463-9090
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
